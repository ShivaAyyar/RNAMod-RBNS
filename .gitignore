# =============================================================================
# RNAMod-RBNS .gitignore
# =============================================================================

# =============================================================================
# Data files (large, downloaded separately)
# =============================================================================
data/genome/*
data/eclip/*.bed
data/rbns/*.csv
data/rbns/*.tsv
data/mods/K562/*.bed
data/mods/HepG2/*.bed
data/mods/raw/
data/reference/
data/download_summary.txt

# Keep directory structure with .gitkeep files
!data/genome/.gitkeep
!data/eclip/.gitkeep
!data/rbns/.gitkeep
!data/mods/.gitkeep
!data/mods/K562/.gitkeep
!data/mods/HepG2/.gitkeep

# =============================================================================
# Results and outputs
# =============================================================================
results/
logs/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# IDE and editors
# =============================================================================
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS generated
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Conda
# =============================================================================
activate_env.sh

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*.bak
*.log

# =============================================================================
# SLURM
# =============================================================================
slurm-*.out
*.README
